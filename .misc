export EDITOR=vim
export PATH=$PATH:$HOME/go/bin:$HOME/.local/bin
export BAT_THEME="DarkNeon"

alias vi='vim'
alias ls='eza -lhg --group-directories-first --icons=auto'
alias ll='spf --fh --fch "$PWD"'
alias sm='systemd-manager-tui'
alias pcp='pcopy copy'
alias ppaste='pcopy paste'
alias cheat='cheat -a'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

bind 'set enable-bracketed-paste on'